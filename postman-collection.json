        {
          "name": "7. Get Single Movie - Success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const firstMovieId = pm.environment.get('firstMovieId');",
                  "if (!firstMovieId) {",
                  "  const getMoviesRequest = {",
                  "    url: pm.environment.get('base_url') + '/movies',",
                  "    method: 'GET'",
                  "  };",
                  "  pm.sendRequest(getMoviesRequest, function(err, response) {",
                  "    if (!err) {",
                  "      try {",
                  "        const data = response.json();",
                  "        if (data.movies && data.movies.length > 0) {",
                  "          const movieId = data.movies[0].id || data.movies[0]._id;",
                  "          pm.environment.set('firstMovieId', movieId);",
                  "        }",
                  "      } catch(e) {",
                  "        console.error('Error parsing movies:', e);",
                  "      }",
                  "    }",
                  "  });",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains movie details', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('id');",
                  "  pm.expect(jsonData).to.have.property('title');",
                  "  pm.expect(jsonData).to.have.property('releaseDate');",
                  "});",
                  "",
                  "pm.test('Response includes HATEOAS links', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('_links');",
                  "});"
                ]
              }
            }
          ],
