      "name": "Authentication",
      "item": [
        {
          "name": "1. Register User - Success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const timestamp = Date.now();",
                  "const randomString = () => Math.random().toString(36).substring(2, 10);",
                  "",
                  "pm.environment.set('firstName', 'Test');",
                  "pm.environment.set('lastName', 'Testest');",
                  "pm.environment.set('main_email', `user_${timestamp}_${randomString()}@example.com`);",
                  "pm.environment.set('main_username', `testuser_${timestamp}_${randomString()}`);",
                  "pm.environment.set('main_password', 'SecurePass123');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains user ID', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('id');",
                  "});",
                  "",
                  "pm.test('Response contains username', function() {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.username).to.equal(pm.environment.get('main_username'));",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "  pm.environment.set('userId', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"{{firstName}}\",\n  \"lastName\": \"{{lastName}}\",\n  \"email\": \"{{main_email}}\",\n  \"username\": \"{{main_username}}\",\n  \"password\": \"{{main_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/user/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "user",
                "register"
              ]
