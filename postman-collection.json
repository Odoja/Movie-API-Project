      "item": [
        {
          "name": "9. Create Movie - Success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const timestamp = Date.now();",
                  "const randomTitle = `Movie ${Math.random().toString(36).substring(7)} ${timestamp}`;",
                  "",
                  "pm.environment.set('movieTitle', randomTitle);",
                  "pm.environment.set('movieOverview', `Test movie created at ${new Date().toISOString()}`);",
                  "pm.environment.set('movieReleaseDate', '2024-01-15');",
                  "",
                  "// Fetch genreId if not already set",
                  "const genreId = pm.environment.get('genreId');",
                  "if (!genreId) {",
                  "  const getGenresRequest = {",
                  "    url: pm.environment.get('base_url') + '/genres',",
                  "    method: 'GET'",
                  "  };",
                  "  pm.sendRequest(getGenresRequest, function(err, response) {",
                  "    if (!err) {",
                  "      try {",
                  "        const data = response.json();",
                  "        if (data && data.length > 0) {",
                  "          const gId = data[0]._id || data[0].id;",
                  "          pm.environment.set('genreId', gId);",
                  "        }",
                  "      } catch(e) {",
                  "        console.error('Error parsing genres:', e);",
                  "      }",
                  "    }",
                  "  });",
                  "}",
                  "",
                  "// Fetch languageId if not already set",
                  "const languageId = pm.environment.get('languageId');",
                  "if (!languageId) {",
                  "  const getLanguagesRequest = {",
                  "    url: pm.environment.get('base_url') + '/languages',",
                  "    method: 'GET'",
                  "  };",
                  "  pm.sendRequest(getLanguagesRequest, function(err, response) {",
                  "    if (!err) {",
                  "      try {",
                  "        const data = response.json();",
                  "        if (data && data.length > 0) {",
                  "          const lId = data[0]._id || data[0].id;",
                  "          pm.environment.set('languageId', lId);",
                  "        }",
                  "      } catch(e) {",
                  "        console.error('Error parsing languages:', e);",
                  "      }",
                  "    }",
                  "  });",
                  "}",
                  ""
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData;",
                  "try {",
                  "  jsonData = pm.response.json();",
                  "} catch(e) {",
                  "  jsonData = {};",
                  "}",
                  "",
                  "pm.test('Status code is 201', function() {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains created movie', function() {",
                  "  pm.expect(jsonData).to.have.property('id');",
                  "  pm.expect(jsonData.title).to.equal(pm.environment.get('movieTitle'));",
                  "});",
                  "",
                  "if (jsonData && jsonData.id) {",
                  "  pm.environment.set('createdMovieId', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
